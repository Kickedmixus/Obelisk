# () for saving command calls
# <> for hanging vaules, using variables in COMMANDMENTS
# [] braket for series, could be for command calls or any vaule
# "" for variable names
# =  for defintions



new var "x";
var."x".val = 14;

new list "list";
list."list".items = [1,2,4,6];
list."list".items.3 = 3;

terminal_display{list."list".items};
terminal_display{list."list".items.3};

terminal_display{list."a".items.<var."x".val>};

new func "func";
func."func" = [(),(),(),()];

new var "i";